<style>
  :root{
    --purple:#5e1b8c;
    --purple-deep:#2c0f4a;
    --purple-ink:#1f0a32;
    --pink:#ff4da6;
    --pink-hot:#ff6ec4;
    --pink-soft:#ffb3e0;
    --blush:#fff0f7;
    --cream:#fff9fb;
    --lavender:#f8e9ff;
    --line:#f0d4f0;
    --grad: linear-gradient(135deg, var(--purple) 0%, var(--pink) 100%);
    --ease: cubic-bezier(.22,.9,.32,1);
    --shadow: 0 12px 32px -12px rgba(94,27,140,.32);
  }

  *{margin:0;padding:0;box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  @media (prefers-reduced-motion: reduce){
    html{scroll-behavior:auto;}
    *{animation-duration:.001ms !important; animation-iteration-count:1 !important; transition-duration:.001ms !important;}
  }

  body{
    font-family:'Manrope',sans-serif;
    background:var(--blush);
    color:var(--purple-ink);
    -webkit-font-smoothing:antialiased;
    overflow-x:hidden;
  }

  img{max-width:100%;display:block;border-radius:12px;}
  a{color:inherit;text-decoration:none;}
  button{font-family:inherit;cursor:pointer;border:none;background:none;color:inherit;}
  ul{list-style:none;}

  .eyebrow{
    font-size:.72rem;letter-spacing:.22em;text-transform:uppercase;
    font-weight:700;color:var(--pink-hot);
  }

  h1,h2,h3,.display{
    font-family:'Fraunces',serif;
    font-weight:700;
    color:var(--purple-deep);
    line-height:1.05;
  }

  .container{max-width:1280px;margin:0 auto;padding:0 20px;}

  .announce{
    background:var(--purple-ink);
    color:var(--pink-soft);
    text-align:center;
    font-size:.78rem;
    letter-spacing:.04em;
    padding:10px 12px;
    font-weight:600;
    position:relative;
    overflow:hidden;
  }
  .announce::before{content:'✦'; position:absolute; left:12px; animation:twinkle 3s infinite;}
  .announce::after{content:'✦'; position:absolute; right:12px; animation:twinkle 3s infinite 0.8s;}
  .announce b{color:#fff;}

  @keyframes twinkle{0%,100%{opacity:0.6;} 50%{opacity:1;}}

  header{
    position:sticky; top:0; z-index:60;
    background:rgba(255,249,251,.88);
    backdrop-filter:blur(16px) saturate(180%);
    border-bottom:1px solid var(--line);
    box-shadow:0 4px 20px -12px rgba(94,27,140,.2);
  }

  .nav-row{
    display:grid;
    grid-template-columns:1fr auto 1fr;
    align-items:center;
    padding:14px 20px;
  }

  .nav-left{
    display:flex;
    align-items:center;
    gap:12px;
    justify-self:start;
  }

  .nav-right{
    display:flex;
    align-items:center;
    gap:8px;
    justify-self:end;
  }

  .icon-btn{
    width:44px;height:44px;
    display:inline-flex;align-items:center;justify-content:center;
    border-radius:50%;
    transition:all .25s var(--ease);
    position:relative;
  }
  .icon-btn:hover{background:var(--lavender); transform:scale(1.08) rotate(8deg);}
  .icon-btn:active{transform:scale(0.92);}

  .hamburger{display:flex; justify-self:start;}
  .hamburger span{display:block;width:22px;height:2.5px;background:var(--purple-deep);border-radius:2px;position:relative;transition:all .3s var(--ease);}
  .hamburger .bars{display:flex;flex-direction:column;gap:5px;}
  .hamburger.active .bar1{transform:translateY(7px) rotate(45deg);}
  .hamburger.active .bar2{opacity:0;}
  .hamburger.active .bar3{transform:translateY(-7px) rotate(-45deg);}

  .wordmark{
    justify-self:center;
    font-family:'Fraunces',serif;
    font-weight:700;
    font-size:clamp(1.2rem, 3vw, 1.75rem);
    letter-spacing:.04em;
    color:var(--purple);
    display:flex;align-items:center;gap:6px;
    white-space:nowrap;
    position:relative;
  }
  .wordmark .by{
    font-style:italic;
    font-weight:500;
    font-size:.65em;
    color:var(--pink-hot);
    letter-spacing:.03em;
  }
  .wordmark .moon{
    display:inline-block;
    width:10px;height:10px;
    background:var(--grad);
    border-radius:50%;
    position:relative;
    box-shadow:0 0 12px var(--pink);
  }
  .wordmark .moon::after{
    content:'';
    position:absolute;
    top:2px; left:2px;
    width:4px;height:4px;
    background:var(--cream);
    border-radius:50%;
  }

  .cart-count{
    position:absolute; top:-2px; right:-2px;
    background:var(--grad); color:#fff;
    font-size:.65rem; font-weight:800;
    width:18px;height:18px;border-radius:50%;
    display:flex;align-items:center;justify-content:center;
    box-shadow:0 0 0 3px var(--cream);
  }

  .scrim{
    position:fixed; inset:0; background:rgba(44,15,74,.48);
    opacity:0; pointer-events:none; transition:opacity .4s var(--ease);
    z-index:70; backdrop-filter:blur(6px);
  }
  .scrim.show{opacity:1; pointer-events:auto;}

  .drawer{
    position:fixed; top:0; bottom:0; width:min(360px, 90vw);
    background:var(--purple-deep); color:#fff;
    z-index:80; transition:transform .5s var(--ease);
    display:flex; flex-direction:column;
    box-shadow:0 0 70px rgba(0,0,0,.4);
  }
  .drawer-left{left:0; transform:translateX(-105%);}
  .drawer-left.open{transform:translateX(0);}

  .drawer-head{
    display:flex; align-items:center; justify-content:space-between;
    padding:24px 24px 16px; border-bottom:1px solid rgba(255,255,255,.15);
  }
  .drawer-head .drawer-logo{font-family:'Fraunces',serif; font-style:italic; font-size:1.3rem; color:var(--pink-soft);}

  .drawer-close{width:40px;height:40px;border-radius:50%; display:flex;align-items:center;justify-content:center; transition:all .3s var(--ease);}
  .drawer-close:hover{background:rgba(255,255,255,.15); transform:rotate(90deg);}

  .drawer-nav{padding:12px 16px 30px; overflow-y:auto; flex:1;}
  .drawer-nav a{
    display:flex; align-items:center; gap:14px;
    padding:14px 16px; border-radius:14px;
    font-size:1rem; font-weight:600;
    color:#f8e9ff;
    transition:all .25s var(--ease);
  }
  .drawer-nav a:hover{background:rgba(255,77,166,.2); color:#fff; transform:translateX(8px);}
  .drawer-nav .orbit-dot{
    width:8px;height:8px;border-radius:50%;background:var(--pink-hot); flex:none;
    box-shadow:0 0 0 4px rgba(255,179,224,.25);
  }

  .drawer-section-label{
    font-size:.7rem; letter-spacing:.2em; text-transform:uppercase;
    color:rgba(255,255,255,.5); padding:20px 16px 8px; font-weight:700;
  }

  .cart-drawer{
    right:0; transform:translateX(105%); background:var(--cream); color:var(--purple-ink);
  }
  .cart-drawer.open{transform:translateX(0);}

  .cart-body{flex:1; overflow-y:auto; padding:10px 24px;}
  .cart-empty{
    display:flex; flex-direction:column; align-items:center; text-align:center;
    padding:80px 20px; gap:16px; color:#9b6fa8;
  }
  .cart-empty .ring{
    width:78px;height:78px;border-radius:50%;
    border:3px dashed var(--pink-soft);
    display:flex;align-items:center;justify-content:center;
    font-size:2rem;
    animation:spin 14s linear infinite;
  }

  .cart-foot{padding:20px 24px 32px; border-top:1px solid var(--line);}
  .cart-subtotal{display:flex; justify-content:space-between; font-weight:700; margin-bottom:12px; font-size:1.1rem;}
  .cart-subtotal span:last-child{color:var(--purple);}

  .btn{
    display:inline-flex; align-items:center; justify-content:center; gap:8px;
    padding:14px 26px; border-radius:9999px;
    font-weight:700; font-size:.9rem; letter-spacing:.02em;
    transition:all .3s var(--ease);
  }
  .btn-primary{background:var(--grad); color:#fff; box-shadow:var(--shadow); width:100%;}
  .btn-primary:hover{transform:translateY(-3px); box-shadow:0 20px 40px -12px rgba(255,77,166,.5);}
  .btn-outline{border:2px solid var(--purple); color:var(--purple);}
  .btn-outline:hover{background:var(--purple); color:#fff;}

  .hero{
    display:grid; grid-template-columns:1fr 1fr; align-items:center; gap:48px;
    padding:80px 20px 60px; max-width:1280px; margin:0 auto;
  }
  .hero-eyebrow{margin-bottom:12px;}
  .hero h1{font-size:clamp(2.8rem, 6vw, 4.6rem); margin-bottom:20px; line-height:1.05;}
  .hero h1 em{color:var(--pink-hot); font-style:italic;}
  .hero p{max-width:460px; color:#6b4a7c; font-size:1.08rem; line-height:1.65; margin-bottom:32px;}
  .hero-ctas{display:flex; gap:16px; flex-wrap:wrap;}

  .orbit-stage{
    position:relative; aspect-ratio:1/1; max-width:520px; margin:0 auto;
  }
  .ring{
    position:absolute; border-radius:50%; border:2px dashed var(--pink-soft);
  }
  .ring-1{inset:0; animation:spin 28s linear infinite;}
  .ring-2{inset:12%; border-color:rgba(94,27,140,.3); animation:spin 38s linear infinite reverse;}
  .ring-3{inset:26%; border-style:solid; border-color:var(--pink-hot); opacity:0.6; animation:spin 22s linear infinite;}

  .eclipse-photo{
    width:78%; aspect-ratio:1/1; border-radius:50%; overflow:hidden;
    box-shadow:0 40px 70px -20px rgba(94,27,140,.5), 0 0 0 14px rgba(255,255,255,.75);
    position:relative; z-index:2;
    border:8px solid transparent;
    background:linear-gradient(white, white) padding-box, var(--grad) border-box;
  }
  .eclipse-photo img{width:100%;height:100%;object-fit:cover; transition:transform .6s ease;}

  .marquee-wrap{
    border-top:1px solid var(--line); border-bottom:1px solid var(--line);
    overflow:hidden; background:var(--lavender); padding:16px 0;
  }
  .marquee{display:flex; width:max-content; animation:marquee 28s linear infinite;}
  .marquee span{
    font-family:'Fraunces',serif; font-style:italic; font-weight:600;
    font-size:1.25rem; color:var(--purple-deep); padding:0 32px; white-space:nowrap;
    display:flex; align-items:center; gap:22px;
  }
  .marquee span::after{content:'🌙'; color:var(--pink);}

  @keyframes marquee{from{transform:translateX(0);} to{transform:translateX(-50%);}}
  @keyframes spin{to{transform:rotate(360deg);}}

  section{padding:78px 0;}
  .section-head{display:flex; align-items:flex-end; justify-content:space-between; margin-bottom:36px; flex-wrap:wrap; gap:12px;}
  .section-head h2{font-size:clamp(1.8rem, 3.5vw, 2.6rem);}

  .grid{
    display:grid; grid-template-columns:repeat(auto-fit, minmax(260px, 1fr)); gap:28px;
    padding:0 20px;
  }
  .card{
    background:var(--cream); border-radius:22px; overflow:hidden;
    border:1px solid var(--line);
    transition:all .4s var(--ease);
    display:flex; flex-direction:column;
    position:relative;
  }
  .card:hover{transform:translateY(-12px); box-shadow:var(--shadow);}
  .card-media{position:relative; aspect-ratio:1/1; overflow:hidden; background:var(--lavender);}
  .card-media img{width:100%;height:100%;object-fit:cover; transition:transform .7s ease;}
  .card:hover .card-media img{transform:scale(1.12);}
  
  /* Pinkish-Purplish Frame */
  .card-media::before{
    content:''; position:absolute; inset:0; z-index:2;
    border:6px solid transparent;
    background:linear-gradient(135deg, var(--purple), var(--pink-hot)) padding-box, 
                linear-gradient(135deg, var(--pink-soft), var(--purple)) border-box;
    border-radius:22px;
    opacity:0.85;
    pointer-events:none;
  }

  .wishlist{
    position:absolute; top:14px; right:14px; width:38px;height:38px; border-radius:50%;
    background:rgba(255,255,255,.9); backdrop-filter:blur(8px);
    display:flex;align-items:center;justify-content:center;
    box-shadow:0 4px 12px rgba(0,0,0,.1);
  }

  .card-body{padding:18px; display:flex; flex-direction:column; gap:8px; flex:1;}
  .card-body .name{font-weight:700; font-size:1rem; color:var(--purple-deep);}
  .card-body .price{color:var(--pink-hot); font-weight:800; font-size:1.05rem;}

  .add-btn{
    margin-top:auto; width:100%; padding:13px; border-radius:9999px;
    background:var(--lavender); color:var(--purple); font-weight:700; font-size:.88rem;
    transition:all .3s var(--ease);
  }
  .add-btn:hover{background:var(--grad); color:#fff; transform:scale(1.03);}

  .newsletter{
    background:var(--grad); border-radius:32px; margin:0 20px;
    padding:64px 36px; text-align:center; color:#fff; position:relative; overflow:hidden;
  }
  .newsletter h2{color:#fff; margin-bottom:12px; font-size:clamp(1.6rem,3.5vw,2.4rem);}
  .newsletter-form{display:flex; max-width:460px; margin:0 auto; gap:12px;}
  .newsletter-form input{
    flex:1; padding:16px 22px; border-radius:9999px; border:none; font-size:1rem;
  }
  .newsletter-form button{
    padding:16px 32px; border-radius:9999px; background:var(--purple-ink); color:#fff; font-weight:700;
  }

  footer{
    background:var(--purple-ink); color:rgba(255,255,255,.85); padding:64px 0 28px;
  }
  .footer-grid{display:grid; grid-template-columns:repeat(auto-fit, minmax(220px, 1fr)); gap:48px;}
  .footer-logo{font-family:'Fraunces',serif; font-style:italic; color:#fff; font-size:1.5rem; margin-bottom:16px;}
  .footer-grid h4{color:#fff; font-size:.85rem; letter-spacing:.12em; text-transform:uppercase; margin-bottom:18px;}
  .footer-grid ul li{margin-bottom:9px; font-size:.9rem;}
  .footer-grid ul li a:hover{color:var(--pink-hot);}

  /* Decorative stars & moons */
  .star{
    position:absolute; color:var(--pink-soft); font-size:1.1rem; opacity:0.6;
    animation:twinkle 4s infinite alternate;
  }

  @media (max-width: 980px){
    .hero{grid-template-columns:1fr; text-align:center;}
    .grid{grid-template-columns:repeat(2, 1fr);}
  }
  @media (max-width: 560px){
    .nav-row{padding:12px 16px;}
    .hero{padding:48px 16px 32px;}
    .grid{gap:18px; padding:0 16px;}
  }
</style>
</head>
