    {id:'crystal', name:'Pink Crystal Butterfly', price:1350, img:'https://picsum.photos/id/201/600/600'},
    {id:'starlight', name:'Starlight Necklace', price:1850, img:'https://picsum.photos/id/251/600/600'},
    {id:'lunar', name:'Lunar Hoop Earrings', price:950, img:'https://picsum.photos/id/180/600/600'},
    {id:'celeste', name:'Celeste Hair Pin Set', price:780, img:'https://picsum.photos/id/314/600/600'}
  ];

  let cart = [];

  function init(){
    renderProducts();
    setupListeners();
    updateCartCount();
  }

  function renderProducts(){
    const grid = document.getElementById('productGrid');
    grid.innerHTML = products.map(p => `
      <div class="card">
        <div class="card-media">
          <img src="\( {p.img}" alt=" \){p.name}" loading="lazy">
        </div>
        <div class="card-body">
          <div class="name">${p.name}</div>
          <div class="price">Rs. ${p.price}</div>
          <button class="add-btn" data-id="${p.id}">Add to Cart 🌙</button>
        </div>
      </div>
    `).join('');
  }

  function setupListeners(){
    // Add to cart
    document.addEventListener('click', e => {
      if(e.target.classList.contains('add-btn')){
        const id = e.target.getAttribute('data-id');
        addToCart(id);
      }
    });

    // Menu & Cart
    const menuBtn = document.getElementById('menuBtn');
    const menuDrawer = document.getElementById('menuDrawer');
    const menuClose = document.getElementById('menuClose');
    const cartBtn = document.getElementById('cartBtn');
    const cartDrawer = document.getElementById('cartDrawer');
    const cartClose = document.getElementById('cartClose');
    const scrim = document.getElementById('scrim');

    menuBtn.addEventListener('click', () => {
      menuDrawer.classList.add('open');
      scrim.classList.add('show');
    });
    menuClose.addEventListener('click', closeDrawers);
    cartBtn.addEventListener('click', () => {
      cartDrawer.classList.add('open');
      scrim.classList.add('show');
      renderCart();
    });
    cartClose.addEventListener('click', closeDrawers);
    scrim.addEventListener('click', closeDrawers);
  }

  function closeDrawers(){
    document.querySelectorAll('.drawer').forEach(d => d.classList.remove('open'));
    document.getElementById('scrim').classList.remove('show');
  }

  function addToCart(id){
    const item = products.find(p => p.id === id);
    if(!item) return;

    const existing = cart.find(c => c.id === id);
    if(existing) existing.qty++;
    else cart.push({...item, qty:1});

    updateCartCount();
    // Open cart automatically
    document.getElementById('cartDrawer').classList.add('open');
    document.getElementById('scrim').classList.add('show');
    renderCart();
  }

  function updateCartCount(){
    const count = cart.reduce((acc, item) => acc + item.qty, 0);
    document.getElementById('cartCount').textContent = count;
  }

  function renderCart(){
    const body = document.getElementById('cartBody');
    const foot = document.getElementById('cartFoot');
    const subtotalEl = document.getElementById('cartSubtotal');

    if(cart.length === 0){
      body.innerHTML = `<div class="cart-empty"><div class="ring">🌙</div><p>Your cart is empty.<br>Fill it with stars!</p></div>`;
      foot.style.display = 'none';
      return;
    }

    const subtotal = cart.reduce((acc, c) => acc + (c.price * c.qty), 0);

    let html = '';
    cart.forEach(item => {
      html += `
        <div style="display:flex;gap:16px;margin-bottom:20px;align-items:center;border-bottom:1px solid #eee;padding-bottom:16px;">
          <img src="${item.img}" style="width:68px;height:68px;object-fit:cover;border-radius:12px;" alt="">
          <div style="flex:1;">
            <div style="font-weight:600;">${item.name}</div>
            <div style="color:var(--pink);font-size:0.9rem;">Rs. ${item.price} × ${item.qty}</div>
          </div>
        </div>`;
    });

    body.innerHTML = html;
    subtotalEl.textContent = `Rs. ${subtotal}`;
    foot.style.display = 'block';
  }

  window.whatsappCheckout = function(){
    if(cart.length === 0) return alert("Your cart is empty!");

    let message = "Hello! I'd like to order:\n\n";
    cart.forEach(item => {
      message += `• ${item.name} × ${item.qty} - Rs. ${item.price * item.qty}\n`;
    });
    const subtotal = cart.reduce((acc, c) => acc + (c.price * c.qty), 0);
    message += `\nSubtotal: Rs. ${subtotal}\n\nPlease confirm Cash on Delivery. Thank you! 🌙`;

    const encoded = encodeURIComponent(message);
    window.open(`https://wa.me/\( {WHATSAPP_NUMBER}?text= \){encoded}`, '_blank');
  };

  document.addEventListener('DOMContentLoaded', init);
})();
</script>
</body>
</html>
